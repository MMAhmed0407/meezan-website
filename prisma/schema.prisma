// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  fullName   String
  email      String
  phone      String?
  course     String?
  message    String
  source     String   // e.g., 'contact_section' or 'floating_widget'
  status     String   @default("new") // e.g., 'new', 'reached', 'replied'

  @@map("contact_submissions")
}
